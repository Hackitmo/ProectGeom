import java.io.*;
import java.util.*;
import javax.swing.*;
import javax.swing.filechooser.FileNameExtensionFilter;
import java.awt.*;
import java.awt.event.*;
import java.awt.geom.*;
import static java.lang.Math.*;

public class Main {
    private static java.util.List<Point2D.Double> points = new ArrayList<>();
    private static JFrame mainFrame;
    private static JTextArea resultArea;

    public static void main(String[] args) {
        SwingUtilities.invokeLater(() -> createAndShowGUI());
    }

    private static void createAndShowGUI() {
        mainFrame = new JFrame("Геометрическая задача");
        mainFrame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        mainFrame.setSize(600, 500);
        mainFrame.setLayout(new BorderLayout());

        // Заголовок
        JLabel title = new JLabel("Выберите способ ввода", SwingConstants.CENTER);
        title.setFont(new Font("Arial", Font.BOLD, 18));
        mainFrame.add(title, BorderLayout.NORTH);

        // Панель с кнопками
        JPanel buttonPanel = new JPanel(new GridLayout(3, 1, 10, 10));
        buttonPanel.setBorder(BorderFactory.createEmptyBorder(20, 50, 20, 50));

        JButton clickButton = new JButton("1. Отметить точки на плоскости");
        JButton fileButton = new JButton("2. Загрузить из файла");
        JButton manualButton = new JButton("3. Ввести вручную");

        styleButton(clickButton);
        styleButton(fileButton);
        styleButton(manualButton);

        buttonPanel.add(clickButton);
        buttonPanel.add(fileButton);
        buttonPanel.add(manualButton);

        mainFrame.add(buttonPanel, BorderLayout.CENTER);

        // Область результатов
        resultArea = new JTextArea(5, 30);
        resultArea.setEditable(false);
        resultArea.setFont(new Font("Monospaced", Font.PLAIN, 14));
        JScrollPane scrollPane = new JScrollPane(resultArea);
        scrollPane.setBorder(BorderFactory.createTitledBorder("Результаты"));
        mainFrame.add(scrollPane, BorderLayout.SOUTH);

        // Обработчики кнопок
        clickButton.addActionListener(e -> openClickPlaneWindow());
        fileButton.addActionListener(e -> loadFromFile());
        manualButton.addActionListener(e -> openManualInputWindow());

        mainFrame.setLocationRelativeTo(null);
        mainFrame.setVisible(true);
    }

    private static void styleButton(JButton button) {
        button.setFont(new Font("Arial", Font.PLAIN, 14));
        button.setFocusPainted(false);
    }

    private static void openClickPlaneWindow() {
        points.clear();
        JFrame planeFrame = new JFrame("Отметьте точки на плоскости");
        planeFrame.setSize(600, 650);
        planeFrame.setLayout(new BorderLayout());

        JLabel instruction = new JLabel("Левая кнопка - добавить точку, Правая кнопка - удалить последнюю",
                SwingConstants.CENTER);
        planeFrame.add(instruction, BorderLayout.NORTH);

        PlanePanel planePanel = new PlanePanel();
        planeFrame.add(planePanel, BorderLayout.CENTER);

        JPanel controlPanel = new JPanel();
        JButton doneButton = new JButton("Вычислить");
        JButton clearButton = new JButton("Очистить всё");
        JLabel countLabel = new JLabel("Точек: 0");

        doneButton.addActionListener(e -> {
            if (points.size() < 2) {
                JOptionPane.showMessageDialog(planeFrame,
                        "Нужно как минимум 2 точки!", "Ошибка", JOptionPane.ERROR_MESSAGE);
            } else {
                calculateAndDisplay();
                planeFrame.dispose();
            }
        });

        clearButton.addActionListener(e -> {
            points.clear();
            countLabel.setText("Точек: 0");
            planePanel.repaint();
        });

        planePanel.addMouseListener(new MouseAdapter() {
            public void mouseClicked(MouseEvent e) {
                if (SwingUtilities.isLeftMouseButton(e)) {
                    points.add(new Point2D.Double(e.getX(), e.getY()));
                    countLabel.setText("Точек: " + points.size());
                    planePanel.repaint();
                } else if (SwingUtilities.isRightMouseButton(e)) {
                    if (!points.isEmpty()) {
                        points.remove(points.size() - 1);
                        countLabel.setText("Точек: " + points.size());
                        planePanel.repaint();
                    }
                }
            }
        });

        controlPanel.add(doneButton);
        controlPanel.add(clearButton);
        controlPanel.add(countLabel);
        planeFrame.add(controlPanel, BorderLayout.SOUTH);

        planeFrame.setLocationRelativeTo(mainFrame);
        planeFrame.setVisible(true);
    }

    static class PlanePanel extends JPanel {
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2 = (Graphics2D) g;
            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);

            int width = getWidth();
            int height = getHeight();

            // Центр панели - начало координат
            int centerX = width / 2;
            int centerY = height / 2;

            // Рисуем сетку
            g2.setColor(new Color(220, 220, 220)); // Светло-серая сетка
            for (int i = 0; i < width; i += 50) {
                g2.drawLine(i, 0, i, height);
            }
            for (int i = 0; i < height; i += 50) {
                g2.drawLine(0, i, width, i);
            }

            // Рисуем оси координат
            g2.setColor(Color.BLACK);
            g2.setStroke(new BasicStroke(2)); // Толщина осей
            // Ось X
            g2.drawLine(0, centerY, width, centerY);
            // Ось Y
            g2.drawLine(centerX, 0, centerX, height);

            // Стрелки на осях
            drawArrow(g2, width - 10, centerY, width, centerY); // Стрелка X
            drawArrow(g2, centerX, 10, centerX, 0); // Стрелка Y

            // Подписи осей
            g2.setFont(new Font("Arial", Font.BOLD, 14));
            g2.drawString("X", width - 20, centerY - 10);
            g2.drawString("Y", centerX + 10, 20);

            // Деления и цифры на осях
            g2.setFont(new Font("Arial", Font.PLAIN, 10));
            g2.setStroke(new BasicStroke(1));

            // Деления по X
            for (int i = centerX + 50; i < width; i += 50) {
                g2.drawLine(i, centerY - 5, i, centerY + 5);
                g2.drawString(String.valueOf((i - centerX) / 50), i - 10, centerY + 20);
            }
            for (int i = centerX - 50; i > 0; i -= 50) {
                g2.drawLine(i, centerY - 5, i, centerY + 5);
                g2.drawString(String.valueOf((i - centerX) / 50), i - 10, centerY + 20);
            }

            // Деления по Y
            for (int i = centerY - 50; i > 0; i -= 50) {
                g2.drawLine(centerX - 5, i, centerX + 5, i);
                g2.drawString(String.valueOf((centerY - i) / 50), centerX + 10, i + 5);
            }
            for (int i = centerY + 50; i < height; i += 50) {
                g2.drawLine(centerX - 5, i, centerX + 5, i);
                g2.drawString(String.valueOf((centerY - i) / 50), centerX + 10, i + 5);
            }

            // Подпись начала координат
            g2.drawString("0", centerX - 12, centerY + 15);

            // Рисуем точки
            g2.setColor(Color.RED);
            for (int i = 0; i < points.size(); i++) {
                Point2D.Double p = points.get(i);
                int x = (int) p.x - 5;
                int y = (int) p.y - 5;

                // Красный круг
                g2.setColor(Color.RED);
                g2.fillOval(x, y, 10, 10);

                // Чёрная обводка
                g2.setColor(Color.BLACK);
                g2.setStroke(new BasicStroke(1));
                g2.drawOval(x, y, 10, 10);

                // Номер точки
                g2.setFont(new Font("Arial", Font.BOLD, 12));
                g2.drawString(String.valueOf(i + 1), (int) p.x + 8, (int) p.y - 8);
            }
        }

        private void drawArrow(Graphics2D g2, int x1, int y1, int x2, int y2) {
            int arrowSize = 8;
            double angle = atan2(y2 - y1, x2 - x1);

            int x3 = (int) (x2 - arrowSize * cos(angle - PI / 6));
            int y3 = (int) (y2 - arrowSize * sin(angle - PI / 6));
            int x4 = (int) (x2 - arrowSize * cos(angle + PI / 6));
            int y4 = (int) (y2 - arrowSize * sin(angle + PI / 6));

            Polygon arrow = new Polygon();
            arrow.addPoint(x2, y2);
            arrow.addPoint(x3, y3);
            arrow.addPoint(x4, y4);

            g2.fill(arrow);
        }
    }

    private static void loadFromFile() {
        JFileChooser fileChooser = new JFileChooser();
        fileChooser.setFileFilter(new FileNameExtensionFilter("Текстовые файлы", "txt"));

        if (fileChooser.showOpenDialog(mainFrame) == JFileChooser.APPROVE_OPTION) {
            try {
                File file = fileChooser.getSelectedFile();
                BufferedReader br = new BufferedReader(new FileReader(file));
                int n = Integer.parseInt(br.readLine().trim());
                points.clear();

                for (int i = 0; i < n; i++) {
                    String[] p = br.readLine().trim().split("[\\s,]+");
                    double px = Double.parseDouble(p[0]);
                    double py = Double.parseDouble(p[1]);
                    points.add(new Point2D.Double(px, py));
                }
                if (points.size() >= 2) {
                    calculateAndDisplay();
                } else {
                    JOptionPane.showMessageDialog(mainFrame,
                            "Нужно как минимум 2 точки!", "Ошибка", JOptionPane.ERROR_MESSAGE);
                }
            } catch (NumberFormatException ex) {
                JOptionPane.showMessageDialog(mainFrame,
                        "Ошибка формата чисел в файле!", "Ошибка", JOptionPane.ERROR_MESSAGE);
            } catch (IOException ex) {
                JOptionPane.showMessageDialog(mainFrame,
                        "Ошибка чтения файла: " + ex.getMessage(), "Ошибка", JOptionPane.ERROR_MESSAGE);
            }
        }
    }

    private static void openManualInputWindow() {
        JDialog dialog = new JDialog(mainFrame, "Ручной ввод", true);
        dialog.setSize(400, 300);
        dialog.setLayout(new BorderLayout());

        JLabel instruction = new JLabel("Введите точки (разделители - запятая или пробел):",
                SwingConstants.CENTER);
        dialog.add(instruction, BorderLayout.NORTH);

        JTextArea inputArea = new JTextArea(10, 30);
        inputArea.setFont(new Font("Monospaced", Font.PLAIN, 14));
        JScrollPane scrollPane = new JScrollPane(inputArea);
        scrollPane.setBorder(BorderFactory.createTitledBorder("Формат: x y (по одной паре на строку)"));
        dialog.add(scrollPane, BorderLayout.CENTER);

        JPanel buttonPanel = new JPanel();
        JButton okButton = new JButton("Вычислить");
        JButton cancelButton = new JButton("Отмена");

        okButton.addActionListener(e -> {
            try {
                points.clear();
                String[] lines = inputArea.getText().trim().split("\n");

                for (String line : lines) {
                    if (!line.trim().isEmpty()) {
                        String[] p = line.trim().split("[\\s,]+");
                        double px = Double.parseDouble(p[0]);
                        double py = Double.parseDouble(p[1]);
                        points.add(new Point2D.Double(px, py));
                    }
                }

                if (points.size() < 2) {
                    JOptionPane.showMessageDialog(dialog,
                            "Нужно как минимум 2 точки!", "Ошибка", JOptionPane.ERROR_MESSAGE);
                } else {
                    calculateAndDisplay();
                    dialog.dispose();
                }
            } catch (NumberFormatException ex) {
                JOptionPane.showMessageDialog(dialog,
                        "Неверный формат чисел!", "Ошибка", JOptionPane.ERROR_MESSAGE);
            }
        });

        cancelButton.addActionListener(e -> dialog.dispose());

        buttonPanel.add(okButton);
        buttonPanel.add(cancelButton);
        dialog.add(buttonPanel, BorderLayout.SOUTH);

        dialog.setLocationRelativeTo(mainFrame);
        dialog.setVisible(true);
    }

    private static void calculateAndDisplay() {
        int n = points.size();
        double[] x = new double[n];
        double[] y = new double[n];

        for (int i = 0; i < n; i++) {
            x[i] = points.get(i).x;
            y[i] = points.get(i).y;
        }

        int h = (n + 1) / 2;
        double[][] d = new double[n][n];
        for (int i = 0; i < n; i++)
            for (int j = 0; j < n; j++)
                d[i][j] = pow(x[i] - x[j], 2) + pow(y[i] - y[j], 2);

        double[] m = new double[n];
        for (int i = 0; i < n; i++) {
            double[] s = d[i].clone();
            Arrays.sort(s);
            m[i] = s[h - 1];
        }

        double min = Double.POSITIVE_INFINITY;
        int bestI = 0, bestJ = 0;
        for (int i = 0; i < n; i++)
            for (int j = i + 1; j < n; j++) {
                double v = min(m[i], m[j]);
                if (v < min) {
                    min = v;
                    bestI = i;
                    bestJ = j;
                }
            }

        double r1 = sqrt(m[bestI]);
        double r2 = sqrt(m[bestJ]);
        double sqrtMin = sqrt(min);

        String result = String.format(
                "Результаты:\n" +
                        "Радиус точки 1: %.4f\n" +
                        "Радиус точки 2: %.4f\n" +
                        "Минимальный радиус: %.4f\n" +
                        "Лучшая пара: Точка %d и Точка %d",
                r1, r2, sqrtMin, bestI + 1, bestJ + 1
        );

        resultArea.setText(result);
        JOptionPane.showMessageDialog(mainFrame, result, "Результаты вычислений",
                JOptionPane.INFORMATION_MESSAGE);
    }
}
